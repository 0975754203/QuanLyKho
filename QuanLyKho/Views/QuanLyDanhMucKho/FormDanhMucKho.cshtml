@using QuanLyKho.Utility
@model QuanLyKho.Models.DanhMucKhoForm
@{
    var coQuyenThaoTac = Global.CoQuyenThaoTacDuLieuKho();
    var laCapNhat = Model != null && Model.Id.HasValue && Model.Id.Value != Guid.Empty;
}

@using (Html.BeginForm("FormDanhMucKho", "QuanLyDanhMucKho", FormMethod.Post, new { enctype = "multipart/form-data", id = "fDanhMucKho", @class = "form-crmnt kho-form" }))
{
    @Html.HiddenFor(x => x.Id)

    <div class="kho-form-intro">
        <h5>Thông tin kho</h5>
        <p>Nhập mã kho, tên kho và địa chỉ để quản lý nơi lưu trữ vật tư.</p>
    </div>

    <div class="kho-form-grid">
        <div class="form-group">
            <label class="text-label">Mã kho <span class="red-crmnt">(*)</span></label>
            @if (laCapNhat)
            {
                @Html.TextBoxFor(x => x.MaKho, new { @class = "form-control input-sm", id = "MaKho", @readonly = "readonly", placeholder = "Nhập mã kho" })
            }
            else
            {
                @Html.TextBoxFor(x => x.MaKho, new { @class = "form-control input-sm", id = "MaKho", placeholder = "Nhập mã kho" })
            }
            @Html.ValidationMessageFor(x => x.MaKho)
        </div>

        <div class="form-group">
            <label class="text-label">Tên kho <span class="red-crmnt">(*)</span></label>
            @Html.TextBoxFor(x => x.TenKho, new { @class = "form-control input-sm", id = "TenKho", placeholder = "Nhập tên kho" })
            @Html.ValidationMessageFor(x => x.TenKho)
        </div>

        <div class="form-group kho-note-field">
            <label class="text-label">Địa chỉ</label>
            @Html.TextAreaFor(x => x.DiaChi, 4, 0, new { @class = "form-control input-sm", placeholder = "Nhập địa chỉ hoặc ghi chú vị trí kho" })
            @Html.ValidationMessageFor(x => x.DiaChi)
        </div>
    </div>

    <div class="kho-form-actions">
        @if (coQuyenThaoTac)
        {
            <button type="submit" class="btn btn-main" id="btnSaveDanhMucKho">
                <i class="ti-save"></i>@(laCapNhat ? "Cập nhật kho" : "Lưu kho")
            </button>
            <button type="button" class="btn btn-main" onclick="ResetDanhMucKhoForm()"><i class="ti-reload"></i>Làm mới</button>
        }
    </div>
}
