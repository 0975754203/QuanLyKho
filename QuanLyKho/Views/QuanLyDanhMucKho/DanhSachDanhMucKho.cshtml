@using QuanLyKho.Utility
@model QuanLyKho.Models.DanhMucKho_DSModel
@{
    var coQuyenThaoTac = Global.CoQuyenThaoTacDuLieuKho();
    var danhSach = Model.TBL_DanhMucKho ?? new System.Collections.Generic.List<BusinessLogic.Model.KhoModel>();
    var stt = (Model.PageIndex - 1) * Model.PageSize;
}

<div class="table-responsive">
    <table class="kho-list-table">
        <thead>
            <tr>
                <th style="width:70px;">STT</th>
                <th style="width:150px;">Mã kho</th>
                <th style="width:220px;">Tên kho</th>
                <th>Địa chỉ</th>
                <th style="width:110px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (danhSach.Count > 0)
            {
                foreach (var item in danhSach)
                {
                    <tr>
                        <td>@(++stt)</td>
                        <td>@item.MaKho</td>
                        <td class="text-left">@item.TenKho</td>
                        <td class="text-left">@(string.IsNullOrWhiteSpace(item.DiaChi) ? "—" : item.DiaChi)</td>
                        <td class="kho-action-cell">
                            @if (coQuyenThaoTac)
                            {
                                <a href="javascript:void(0)" onclick="FormDanhMucKho('@item.Id')" class="kho-action-btn" title="Sửa"><i class="ti-pencil-alt"></i></a>
                                <a href="javascript:void(0)" onclick="DeleteDanhMucKho('@item.Id')" class="kho-action-btn danger" title="Xóa"><i class="ti-trash"></i></a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@Html.GenPaging().PagingHTML(Model.PageIndex, Model.Pagecount, Model.Total)
<input type="hidden" id="pageIndex" name="pageIndex" value="@Model.PageIndex" />
