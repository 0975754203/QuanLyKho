@using QuanLyKho.Utility
@using SQLDataAccess;
@using System
@model  QuanLyKho.Models.TaiKhoan_DSModel
@{ var uow = new UnitOfWork(); }
@{
    var login = QuanLyKho.Utility.Global.ThongTinTaiKhoan_Login;
    var laAdmin = Global.IsAdmin();
}
<style>
    .account-list-table th,
    .account-list-table td {
        text-align: center;
        vertical-align: middle !important;
    }

    .account-list-table .account-actions {
        justify-content: center;
    }
</style>

<div class="table-responsive">
    <table class="table table-striped table-bordered verticle-middle table-hover table-responsive-fix-big account-list-table">
        <thead>
            <tr>
                <th scope="col" class="">STT</th>
                <th scope="col" class="">Tên đăng nhập</th>
                <th scope="col" class="">Loại tài khoản</th>
                <th scope="col" class="">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{ var i = 0;}
            @foreach (var item in Model.TBL_TaiKhoan)
            {
                <tr>
                    <td>@(++i)</td>
                    <td>@item.UserName</td>
                    @if (string.Equals(item.Role, "admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <td>Admin</td>
                    }
                    else if (string.Equals(item.Role, "nhanvien", StringComparison.OrdinalIgnoreCase))
                    {
                        <td>Nhân viên</td>
                    }
                    else if (string.Equals(item.Role, "tho", StringComparison.OrdinalIgnoreCase))
                    {
                        <td>Thợ</td>
                    }
                    else
                    {
                        <td>@item.Role</td>
                    }

                    <td>
                        @if (laAdmin)
                        {
                            <div class="account-actions">
                                <button type="button" onclick="FormUser('@item.Id')" class="account-action-btn" title="Sửa"><i class="ti-pencil-alt"></i></button>
                                <button type="button" onclick="DeleteUser('@item.Id')" class="account-action-btn delete" title="Xóa"><i class="ti-trash"></i></button>
                            </div>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    @*&& PhienBan ==  BusinessLogic.Utils.HangSo.PhienBan.NhapDiem*@
                </tr>
            }
        </tbody>
    </table>
</div>
@Html.GenPaging().PagingHTML(Model.PageIndex, Model.Pagecount, Model.Total)
<input type="hidden" id="pageIndex" name="pageIndex" value="@Model.PageIndex" />
