@using QuanLyKho.Utility
@using SQLDataAccess;
@using System
@model  QuanLyKho.Models.TaiKhoan_DSModel
@{ var uow = new UnitOfWork(); }
@{
    var login = QuanLyKho.Utility.Global.ThongTinTaiKhoan_Login;
    var laAdmin = Global.IsAdmin();
}
<div class="table-responsive">
    <table class="table table-striped table-bordered verticle-middle table-hover  table-responsive-fix-big">
        <thead>
            <tr>
                <th scope="col" class="">STT</th>
                <th scope="col" class="">Tên đăng nhập</th>
                <th scope="col" class="">Loại tài khoản</th>
                <th scope="col" class="">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{ var i = 0;}
            @foreach (var item in Model.TBL_TaiKhoan)
            {
                <tr>
                    <td>@(++i)</td>
                    <td>@item.UserName</td>
                    @if (string.Equals(item.Role, "admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <td>Admin</td>
                    }
                    else if (string.Equals(item.Role, "nhanvien", StringComparison.OrdinalIgnoreCase))
                    {
                        <td>Nhân viên</td>
                    }
                    else if (string.Equals(item.Role, "tho", StringComparison.OrdinalIgnoreCase))
                    {
                        <td>Thợ</td>
                    }
                    else
                    {
                        <td>@item.Role</td>
                    }

                    <td>
                        @if (laAdmin)
                        {
                            <a href="#" onclick="FormUser('@item.Id')" class="mr-3" title="Sửa"><i class="ti-pencil-alt"></i></a>
                            <a href="#" onclick="DeleteUser('@item.Id')" class="mr-3" title="Xóa"><i class="ti-trash"></i></a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    @*&& PhienBan ==  BusinessLogic.Utils.HangSo.PhienBan.NhapDiem*@
                </tr>
            }
        </tbody>
    </table>
</div>
@Html.GenPaging().PagingHTML(Model.PageIndex, Model.Pagecount, Model.Total)
<input type="hidden" id="pageIndex" name="pageIndex" value="@Model.PageIndex" />