@using QuanLyKho.Utility
@using BusinessLogic.Utils;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var laAdmin = Global.IsAdmin();
}

<style>
    .account-page {
        color: #263238;
    }

    .account-hero {
        background: #ffffff;
        border: 1px solid #e7edf3;
        border-radius: 8px;
        padding: 22px 24px;
        margin-bottom: 18px;
        box-shadow: 0 10px 30px rgba(31, 45, 61, 0.06);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .account-hero h3 {
        font-size: 24px;
        font-weight: 700;
        margin: 0 0 6px;
        color: #17324d;
    }

    .account-hero p {
        margin: 0;
        color: #6b7c8f;
        font-size: 14px;
    }

    .account-layout {
        display: grid;
        grid-template-columns: minmax(320px, 420px) minmax(0, 1fr);
        gap: 18px;
        align-items: start;
    }

    .account-card {
        background: #ffffff;
        border: 1px solid #e7edf3;
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(31, 45, 61, 0.06);
        overflow: hidden;
    }

    .account-card-header {
        padding: 18px 20px;
        border-bottom: 1px solid #edf1f5;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .account-card-header h4 {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
        color: #17324d;
    }

    .account-card-header span {
        color: #6b7c8f;
        font-size: 13px;
    }

    .account-card-body {
        padding: 20px;
    }

    .account-toolbar {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) auto auto;
        gap: 10px;
        align-items: center;
    }

    .account-toolbar .form-control {
        height: 42px;
        border-radius: 6px;
    }

    .account-empty-permission {
        padding: 18px;
        border: 1px dashed #cdd8e4;
        border-radius: 8px;
        background: #f8fbfd;
        color: #6b7c8f;
    }

    .account-delete-panel {
        display: none;
        margin-top: 14px;
        padding: 14px 16px;
        border: 1px solid #ffd6d6;
        border-radius: 8px;
        background: #fff7f7;
    }

    .account-delete-panel strong {
        color: #bf1f1f;
        display: block;
        margin-bottom: 4px;
    }

    .account-delete-actions {
        margin-top: 12px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .account-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .account-action-btn {
        width: 34px;
        height: 34px;
        border-radius: 6px;
        border: 1px solid #dbe4ee;
        background: #ffffff;
        color: #345;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .account-action-btn:hover,
    .account-action-btn:focus {
        color: #ffffff;
        background: #1f7a63;
        border-color: #1f7a63;
    }

    .account-action-btn.delete:hover,
    .account-action-btn.delete:focus {
        background: #c0392b;
        border-color: #c0392b;
    }

    .account-table-wrap .table-crmnt {
        margin-top: 0;
    }

    @@media (max-width: 991px) {
        .account-hero,
        .account-card-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .account-layout {
            grid-template-columns: 1fr;
        }

        .account-toolbar {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="account-page">
    <div class="account-hero">
        <div>
            <h3>Quản lý tài khoản</h3>
            <p>Thêm, cập nhật và xóa tài khoản ngay trên một màn hình.</p>
        </div>
        @if (laAdmin)
        {
            <button type="button" class="btn btn-main" onclick="FormUser('')"><i class="ti-plus"></i>Thêm tài khoản</button>
        }
    </div>

    <div class="account-layout">
        @if (laAdmin)
        {
            <div class="account-card">
                <div class="account-card-header">
                    <div>
                        <h4>Thông tin tài khoản</h4>
                        <span id="accountFormSubTitle">Nhập thông tin để thêm mới hoặc chọn sửa trong danh sách.</span>
                    </div>
                </div>
                <div class="account-card-body" id="accountFormPanel">
                    @Html.Action("FormTaiKhoan", "QuanLyTaiKhoan", new { id = "" })
                </div>
            </div>
        }
        else
        {
            <div class="account-card">
                <div class="account-card-body">
                    <div class="account-empty-permission">Bạn chỉ có quyền xem danh sách tài khoản.</div>
                </div>
            </div>
        }

        <div class="account-card account-table-wrap">
            <div class="account-card-header">
                <div>
                    <h4>Danh sách tài khoản</h4>
                    <span>Tìm kiếm theo tên đăng nhập và thao tác trực tiếp trên từng dòng.</span>
                </div>
            </div>
            <div class="account-card-body">
                <div class="account-toolbar">
                    <input type="text" id="txtName" class="form-control input-sm" value="" name="fname" placeholder="Tên đăng nhập">
                    <button type="button" class="btn btn-search-crmnt" onclick="DanhSachUser(1)" id="btnTimKiem"><i class="ti-search"></i>Tìm kiếm</button>
                    @if (laAdmin)
                    {
                        <button type="button" class="btn btn-main" onclick="FormUser('')"><i class="ti-reload"></i>Làm mới form</button>
                    }
                </div>

                <div class="account-delete-panel" id="deletePanel">
                    <strong>Xác nhận xóa tài khoản</strong>
                    <span>Bạn có chắc chắn muốn xóa tài khoản này không?</span>
                    <input type="hidden" id="delete_id" />
                    <div class="account-delete-actions">
                        <button type="button" class="btn btn-main" onclick="ActionDelete()"><i class="ti-trash"></i>Xóa</button>
                        <button type="button" class="btn btn-main" onclick="CancelDelete()"><i class="ti-close"></i>Hủy</button>
                    </div>
                </div>

                <div class="table-crmnt table-job" id="content_Truong"></div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $(".select2").select2();
        DanhSachUser(1);
    });

    $("#txtName").on('keypress', function (e) {
        if (e.keyCode === 13) {
            DanhSachUser(1);
        }
    });

    function DanhSachUser(pageIndex) {
        var name = $("#txtName").val();
        $("#LoadingModal").modal('show');
        $.ajax({
            type: "GET",
            url: '@Url.Action("DanhSachTaiKhoan")',
            data: {
                pageIndex: pageIndex,
                name: name
            },
            dataType: "html",
            success: function (data) {
                $("#content_Truong").html(data);
                setTimeout(function () { $("#LoadingModal").modal('hide'); }, 300);
            },
            error: function () {
                $("#LoadingModal").modal('hide');
                toastr.error("Không tải được danh sách tài khoản.", "Thông báo", { timeOut: 5e3, closeButton: !0, progressBar: !0, positionClass: "toast-top-right" });
            }
        });
    }

    function pagingData(pageIndex) {
        DanhSachUser(pageIndex);
    }

    function FormUser(id) {
        $.ajax({
            type: "GET",
            url: '/QuanLyTaiKhoan/FormTaiKhoan',
            data: { id: id },
            dataType: "html",
            success: function (data) {
                $("#accountFormPanel").html(data);
                $("#accountFormSubTitle").text(id ? "Đang cập nhật tài khoản đã chọn." : "Nhập thông tin để thêm mới hoặc chọn sửa trong danh sách.");
                $("html, body").animate({ scrollTop: $(".account-page").offset().top - 20 }, 250);
            },
            error: function () {
                toastr.error("Không tải được form tài khoản.", "Thông báo", { timeOut: 5e3, closeButton: !0, progressBar: !0, positionClass: "toast-top-right" });
            }
        });
    }

    function DeleteUser(id) {
        $("#delete_id").val(id);
        $("#deletePanel").slideDown(150);
    }

    function CancelDelete() {
        $("#delete_id").val("");
        $("#deletePanel").slideUp(150);
    }

    function ActionDelete() {
        $.ajax({
            type: "POST",
            url: '/QuanLyTaiKhoan/XoaTaiKhoan',
            data: { id: $("#delete_id").val() },
            dataType: "json",
            success: function (data) {
                if (data.Sucess) {
                    CancelDelete();
                    DanhSachUser($("#pageIndex").val() || 1);
                    FormUser('');
                    toastr.success("Xóa thành công.", "Thông báo", { timeOut: 5e3, closeButton: !0, progressBar: !0, positionClass: "toast-top-right" });
                } else {
                    toastr.warning("Không xóa được tài khoản này.", "Cảnh báo", { timeOut: 5e3, closeButton: !0, progressBar: !0, positionClass: "toast-top-right" });
                }
            },
            error: function () {
                toastr.error("Xảy ra lỗi khi xóa tài khoản.", "Thông báo", { timeOut: 5e3, closeButton: !0, progressBar: !0, positionClass: "toast-top-right" });
            }
        });
    }
</script>
