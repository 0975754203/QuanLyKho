@using QuanLyKho.Utility
@model QuanLyKho.Models.KhoSanPham_DSModel
@{
    var laCoQuyenThaoTac = Global.CoQuyenThaoTacDuLieuKho();
    var danhSach = Model.TBL_SanPham ?? new System.Collections.Generic.List<BusinessLogic.Model.KhoSanPhamModel>();
    decimal totalDonGia = danhSach.Sum(x => x.DonGia);
    var stt = (Model.PageIndex - 1) * Model.PageSize;
}

<div class="table-responsive">
    <table class="sanpham-list-table">
        <thead>
            <tr>
                <th style="width:70px;">STT</th>
                <th style="width:130px;">Mã vật tư</th>
                <th>Tên vật tư</th>
                <th style="width:130px;">Đơn giá</th>
                <th style="width:130px;">Xuất xứ</th>
                <th style="width:130px;">Bảo hành</th>
                <th style="width:110px;">Đơn vị</th>
                <th style="width:150px;">Nhóm vật tư</th>
                <th>Ghi chú</th>
                <th style="width:110px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (danhSach.Count > 0)
            {
                foreach (var item in danhSach)
                {
                    <tr>
                        <td>@(++stt)</td>
                        <td>@item.MaSanPham</td>
                        <td class="text-left">@item.TenSanPham</td>
                        <td class="sanpham-price">@item.DonGia.ToString("N0")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.XuatXu) ? "—" : item.XuatXu)</td>
                        <td>@(string.IsNullOrWhiteSpace(item.ThoiGianBaoHanh) ? "—" : item.ThoiGianBaoHanh)</td>
                        <td>@item.sDonViTinh</td>
                        <td>@(string.IsNullOrEmpty(item.TenNhomVatTu) ? "—" : item.TenNhomVatTu)</td>
                        <td class="text-left">@(string.IsNullOrWhiteSpace(item.GhiChu) ? "—" : item.GhiChu)</td>
                        <td class="sanpham-action-cell">
                            @if (laCoQuyenThaoTac)
                            {
                                <a href="javascript:void(0)" onclick="FormSanPham('@item.Id')" class="sanpham-action-btn" title="Sửa"><i class="ti-pencil-alt"></i></a>
                                <a href="javascript:void(0)" onclick="DeleteSanPham('@item.Id')" class="sanpham-action-btn danger" title="Xóa"><i class="ti-trash"></i></a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
                <tr class="font-weight-bold">
                    <td colspan="3" class="text-left">Tổng đơn giá</td>
                    <td class="sanpham-price">@totalDonGia.ToString("N0")</td>
                    <td colspan="6"></td>
                </tr>
            }
            else
            {
                <tr>
                    <td colspan="10">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@Html.GenPaging().PagingHTML(Model.PageIndex, Model.Pagecount, Model.Total)
<input type="hidden" id="pageIndex" name="pageIndex" value="@Model.PageIndex" />
