@using QuanLyKho.Utility
@model QuanLyKho.Models.KhoSanPhamForm
@{
    var coQuyenThaoTac = Global.CoQuyenThaoTacDuLieuKho();
    var laCapNhat = Model != null && Model.Id.HasValue && Model.Id.Value != Guid.Empty;
}

@using (Html.BeginForm("FormSanPham", "QuanLySanPham", FormMethod.Post, new { enctype = "multipart/form-data", id = "fSanPham", @class = "form-crmnt sanpham-form" }))
{
    @Html.HiddenFor(x => x.Id)

    <div class="sanpham-form-intro">
        <h5>Thông tin vật tư</h5>
        <p>Nhập thông tin cơ bản, đơn giá, đơn vị tính và nhóm vật tư.</p>
    </div>

    <div class="sanpham-form-grid">
        <div class="form-group">
            <label class="text-label">Mã vật tư</label>
            @Html.TextBoxFor(x => x.MaSanPham, new { @class = "form-control input-sm", @readonly = "readonly", placeholder = "Tự sinh sau khi lưu" })
            @Html.ValidationMessageFor(x => x.MaSanPham)
        </div>

        <div class="form-group sanpham-name-field">
            <label class="text-label">Tên vật tư <span class="red-crmnt">(*)</span></label>
            @Html.TextBoxFor(x => x.TenSanPham, new { @class = "form-control input-sm", placeholder = "Nhập tên vật tư" })
            @Html.ValidationMessageFor(x => x.TenSanPham)
        </div>

        <div class="form-group">
            <label class="text-label">Đơn giá <span class="red-crmnt">(*)</span></label>
            @Html.TextBoxFor(x => x.DonGia, new { @class = "form-control input-sm", type = "number", step = "0.01", min = "0", placeholder = "Nhập đơn giá" })
            @Html.ValidationMessageFor(x => x.DonGia)
        </div>

        <div class="form-group">
            <label class="text-label">Xuất xứ</label>
            @Html.TextBoxFor(x => x.XuatXu, new { @class = "form-control input-sm", placeholder = "Ví dụ: Việt Nam" })
            @Html.ValidationMessageFor(x => x.XuatXu)
        </div>

        <div class="form-group">
            <label class="text-label">Đơn vị tính <span class="red-crmnt">(*)</span></label>
            @Html.DropDownListFor(x => x.IdDonViTinh, new SelectList(SelectData.ComboDonViTinh(), "Value", "Text"), new { autocomplete = "off", @class = "form-control select2 sanpham-select" })
            @Html.ValidationMessageFor(x => x.IdDonViTinh)
        </div>

        <div class="form-group">
            <label class="text-label">Nhóm vật tư <span class="red-crmnt">(*)</span></label>
            @Html.DropDownListFor(x => x.IdNhomVatTu, new SelectList(SelectData.ComboNhomVatTu(), "Value", "Text"), new { autocomplete = "off", @class = "form-control select2 sanpham-select" })
            @Html.ValidationMessageFor(x => x.IdNhomVatTu)
        </div>

        <div class="form-group">
            <label class="text-label">Ký hiệu nhãn mác</label>
            @Html.TextBoxFor(x => x.KyhieuNhanmac, new { @class = "form-control input-sm", placeholder = "Nhập ký hiệu" })
            @Html.ValidationMessageFor(x => x.KyhieuNhanmac)
        </div>

        <div class="form-group">
            <label class="text-label">Thời gian bảo hành</label>
            @Html.TextBoxFor(x => x.ThoiGianBaoHanh, new { @class = "form-control input-sm", placeholder = "Ví dụ: 12 tháng" })
            @Html.ValidationMessageFor(x => x.ThoiGianBaoHanh)
        </div>

        <div class="form-group sanpham-note-field">
            <label class="text-label">Ghi chú</label>
            @Html.TextAreaFor(x => x.GhiChu, 3, 0, new { @class = "form-control input-sm", placeholder = "Nhập ghi chú" })
            @Html.ValidationMessageFor(x => x.GhiChu)
        </div>
    </div>

    <div class="sanpham-form-actions">
        @if (coQuyenThaoTac)
        {
            <button type="submit" class="btn btn-main" id="btnSaveSanPham">
                <i class="ti-save"></i>@(laCapNhat ? "Cập nhật vật tư" : "Lưu vật tư")
            </button>
            <button type="button" class="btn btn-main" onclick="ResetSanPhamForm()"><i class="ti-reload"></i>Làm mới</button>
        }
    </div>
}
