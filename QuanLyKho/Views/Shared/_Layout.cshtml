    <!--Sửa tab trong dropdown-->
    <script>
        $(document).ready(function () {
            $('.default-tab-mes .dropdown-content-heading li').on('click', function (event) {
                //The event won't be propagated to the document NODE and
                // therefore events delegated to document won't be fired
                event.stopPropagation();
            });

            $('.default-tab-mes .dropdown-content-heading li').on('click', function (event) {
                //The event won't be propagated to the document NODE and
                // therefore events delegated to document won't be fired
                event.stopPropagation();
            });

            $('.default-tab-mes .dropdown-content-heading > ul > li > a').on('click', function (event) {
                event.stopPropagation();
                $(this).tab('show')
            });
        });</script>



