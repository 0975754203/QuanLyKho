@using QuanLyKho.Utility
@model QuanLyKho.Models.KhoTon_DSModel

@{
    decimal totalTonKho = 0;
    decimal totalGiaTri = 0;
}

<div class="table-responsive">
    <table class="table table-striped table-bordered verticle-middle table-hover table-responsive-fix-big">
        <thead>
            <tr>
                <th scope="col">STT</th>
                <th scope="col">Mã sản phẩm</th>
                <th scope="col">Tên sản phẩm</th>
                <th scope="col">Kho</th>
                <th scope="col">Đơn vị</th>
                <th scope="col" class="text-right">Tồn kho</th>
                <th scope="col" class="text-right">Đơn giá</th>
                <th scope="col">Thời gian bảo hành</th>
                <th scope="col" class="text-right">Tổng tiền</th>
            </tr>
        </thead>
        <tbody>
            @{ var i = 0; }
            @if (Model.TBL_TonKho != null && Model.TBL_TonKho.Count > 0)
            {
                foreach (var item in Model.TBL_TonKho)
                {
                    var tongTien = item.DonGia * item.TonKho;
                    totalTonKho += item.TonKho;
                    totalGiaTri += tongTien;
                    <tr>
                        <td>@(++i)</td>
                        <td>@item.MaSanPham</td>
                        <td>@item.TenSanPham</td>
                        <td>@item.TenKho</td>
                        <td>@item.DonViTinh</td>
                        <td class="text-right">@string.Format("{0:n0}", item.TonKho)</td>
                        <td class="text-right">@string.Format("{0:n0}", item.DonGia)</td>
                        <td>@(string.IsNullOrWhiteSpace(item.ThoiGianBaoHanh) ? "—" : item.ThoiGianBaoHanh)</td>
                        <td class="text-right">@string.Format("{0:n0}", tongTien)</td>
                    </tr>
                }
                <tr class="table-info">
                    <td colspan="5" class="text-right font-weight-bold">Tổng cộng:</td>
                    <td class="text-right font-weight-bold">@string.Format("{0:n0}", totalTonKho)</td>
                    <td></td>
                    <td></td>
                    <td class="text-right font-weight-bold">@string.Format("{0:n0}", totalGiaTri)</td>
                </tr>
            }
            else
            {
                <tr>
                    <td colspan="9">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@Html.GenPaging().PagingHTML(Model.PageIndex, Model.Pagecount, Model.Total)
<input type="hidden" id="pageIndex" name="pageIndex" value="@Model.PageIndex" />

