@using QuanLyKho.Utility
@model QuanLyKho.Models.KhoTon_DSModel

<div class="table-responsive">
    <table class="table table-striped table-bordered verticle-middle table-hover table-responsive-fix-big">
        <thead>
            <tr>
                <th scope="col">STT</th>
                <th scope="col">Mã sản phẩm</th>
                <th scope="col">Tên sản phẩm</th>
                <th scope="col">Kho</th>
                <th scope="col">Đơn vị</th>
                <th scope="col" class="text-right">Tồn kho</th>
            </tr>
        </thead>
        <tbody>
            @{ var i = 0; }
            @if (Model.TBL_TonKho != null && Model.TBL_TonKho.Count > 0)
            {
                foreach (var item in Model.TBL_TonKho)
                {
                    <tr>
                        <td>@(++i)</td>
                        <td>@item.MaSanPham</td>
                        <td>@item.TenSanPham</td>
                        <td>@item.TenKho</td>
                        <td>@item.DonViTinh</td>
                        <td class="text-right">@string.Format("{0:n0}", item.TonKho)</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@Html.GenPaging().PagingHTML(Model.PageIndex, Model.Pagecount, Model.Total)
<input type="hidden" id="pageIndex" name="pageIndex" value="@Model.PageIndex" />

