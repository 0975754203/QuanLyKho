@model QuanLyKho.Models.BaoCaoXuatNhapTonPrintModel
@{
    Layout = "~/Views/Shared/_LayoutPrint.cshtml";
    var data = Model.TBL_BaoCaoXuatNhapTon ?? new System.Collections.Generic.List<BusinessLogic.Model.BaoCaoXuatNhapTonModel>();
    decimal tongTonDauKy = 0;
    decimal tongNhapTrongKy = 0;
    decimal tongXuatTrongKy = 0;
    decimal tongTonCuoiKy = 0;

    foreach (var item in data)
    {
        tongTonDauKy += item.TonDauKy;
        tongNhapTrongKy += item.NhapTrongKy;
        tongXuatTrongKy += item.XuatTrongKy;
        tongTonCuoiKy += item.TonCuoiKy;
    }
}

<style>
    .xnt-print-wrap {
        color: #000;
        font-family: "Times New Roman", Times, serif;
        font-size: 12pt;
        padding: 18px 28px;
    }

    .xnt-print-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .xnt-print-header p {
        margin: 0 0 4px;
    }

    .xnt-print-title {
        text-align: center;
        margin: 10px 0 14px;
    }

    .xnt-print-title h2 {
        font-size: 18pt;
        margin: 0 0 6px;
        font-weight: 700;
    }

    .xnt-print-info {
        margin: 0 0 10px;
        line-height: 1.6;
    }

    .xnt-print-table {
        width: 100%;
        border-collapse: collapse;
    }

    .xnt-print-table th,
    .xnt-print-table td {
        border: 1px solid #000;
        padding: 6px 5px;
        vertical-align: middle;
    }

    .xnt-print-table th {
        text-align: center;
        font-weight: 700;
    }

    .xnt-print-table .center {
        text-align: center;
    }

    .xnt-print-table .right {
        text-align: right;
    }

    .xnt-print-total td {
        font-weight: 700;
    }

    .xnt-sign {
        width: 100%;
        margin-top: 24px;
        text-align: center;
    }

    .xnt-sign td {
        width: 33.33%;
        vertical-align: top;
        padding: 4px;
    }

    .xnt-sign-role {
        font-weight: 700;
    }

    .xnt-actions {
        margin-top: 24px;
        text-align: right;
    }

    .xnt-actions button {
        padding: 8px 14px;
        cursor: pointer;
    }

    @@media print {
        .xnt-actions {
            display: none !important;
        }

        .xnt-print-wrap {
            padding: 0;
        }
    }
</style>

<div class="xnt-print-wrap">
    <div class="xnt-print-header">
        <div>
            <p><strong>Đơn vị:</strong> BỆNH VIỆN K</p>
            <p><strong>Bộ phận:</strong> PHÒNG QUẢN TRỊ</p>
        </div>
        <div style="text-align:center;">
            <p><strong>Mẫu báo cáo xuất nhập tồn</strong></p>
            <p>In ngày @DateTime.Now.ToString("dd/MM/yyyy")</p>
        </div>
    </div>

    <div class="xnt-print-title">
        <h2>BÁO CÁO XUẤT NHẬP TỒN</h2>
        <div>Từ ngày @Model.TuNgay.ToString("dd/MM/yyyy") đến ngày @Model.DenNgay.ToString("dd/MM/yyyy")</div>
    </div>

    <div class="xnt-print-info">
        <div><strong>Kho:</strong> @Model.TenKho</div>
    </div>

    <table class="xnt-print-table">
        <thead>
            <tr>
                <th style="width:6%;">STT</th>
                <th>Tên sản phẩm</th>
                <th style="width:14%;">Tồn đầu kỳ</th>
                <th style="width:14%;">Nhập trong kỳ</th>
                <th style="width:14%;">Xuất trong kỳ</th>
                <th style="width:14%;">Tồn cuối kỳ</th>
            </tr>
        </thead>
        <tbody>
            @if (data.Count > 0)
            {
                var stt = 0;
                foreach (var item in data)
                {
                    <tr>
                        <td class="center">@(++stt)</td>
                        <td>@item.TenSanPham</td>
                        <td class="right">@item.TonDauKy.ToString("n2")</td>
                        <td class="right">@item.NhapTrongKy.ToString("n2")</td>
                        <td class="right">@item.XuatTrongKy.ToString("n2")</td>
                        <td class="right">@item.TonCuoiKy.ToString("n2")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="center">Không có dữ liệu</td>
                </tr>
            }
            <tr class="xnt-print-total">
                <td colspan="2" class="center">Tổng cộng</td>
                <td class="right">@tongTonDauKy.ToString("n2")</td>
                <td class="right">@tongNhapTrongKy.ToString("n2")</td>
                <td class="right">@tongXuatTrongKy.ToString("n2")</td>
                <td class="right">@tongTonCuoiKy.ToString("n2")</td>
            </tr>
        </tbody>
    </table>

    <table class="xnt-sign">
        <tr>
            <td></td>
            <td></td>
            <td><em>Ngày @DateTime.Now.Day tháng @DateTime.Now.Month năm @DateTime.Now.Year</em></td>
        </tr>
        <tr>
            <td>
                <div class="xnt-sign-role">Người lập phiếu</div>
                <div><em>(Ký, họ tên)</em></div>
            </td>
            <td>
                <div class="xnt-sign-role">Thủ kho</div>
                <div><em>(Ký, họ tên)</em></div>
            </td>
            <td>
                <div class="xnt-sign-role">Kế toán trưởng</div>
                <div><em>(Ký, họ tên)</em></div>
            </td>
        </tr>
    </table>

    <div class="xnt-actions">
        <button type="button" onclick="window.print();">In phiếu</button>
    </div>
</div>

<script>
    window.onload = function () {
        window.print();
    };
</script>
