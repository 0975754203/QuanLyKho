@using QuanLyKho.Utility
@model QuanLyKho.Models.NhomVatTuForm
@{
    var coQuyenThaoTac = Global.CoQuyenThaoTacDuLieuKho();
    var laCapNhat = Model != null && Model.Id.HasValue && Model.Id.Value != Guid.Empty;
}

@using (Html.BeginForm("FormNhomVatTu", "QuanLyNhomVatTu", FormMethod.Post, new { enctype = "multipart/form-data", id = "fNhomVatTu", @class = "form-crmnt nhom-form" }))
{
    @Html.HiddenFor(x => x.Id)

    <div class="nhom-form-intro">
        <h5>Thông tin nhóm vật tư</h5>
        <p>Nhập mã nhóm và tên nhóm để phân loại danh sách vật tư.</p>
    </div>

    <div class="nhom-form-grid">
        <div class="form-group">
            <label class="text-label">Mã nhóm <span class="red-crmnt">(*)</span></label>
            @if (laCapNhat)
            {
                @Html.TextBoxFor(x => x.MaNhom, new { @class = "form-control input-sm", id = "MaNhom", @readonly = "readonly", placeholder = "Nhập mã nhóm" })
            }
            else
            {
                @Html.TextBoxFor(x => x.MaNhom, new { @class = "form-control input-sm", id = "MaNhom", placeholder = "Nhập mã nhóm" })
            }
            @Html.ValidationMessageFor(x => x.MaNhom)
        </div>

        <div class="form-group">
            <label class="text-label">Tên nhóm <span class="red-crmnt">(*)</span></label>
            @Html.TextBoxFor(x => x.TenNhom, new { @class = "form-control input-sm", id = "TenNhom", placeholder = "Nhập tên nhóm vật tư" })
            @Html.ValidationMessageFor(x => x.TenNhom)
        </div>
    </div>

    <div class="nhom-form-actions">
        @if (coQuyenThaoTac)
        {
            <button type="submit" class="btn btn-main" id="btnSaveNhomVatTu">
                <i class="ti-save"></i>@(laCapNhat ? "Cập nhật nhóm" : "Lưu nhóm")
            </button>
            <button type="button" class="btn btn-main" onclick="ResetNhomVatTuForm()"><i class="ti-reload"></i>Làm mới</button>
        }
    </div>
}
