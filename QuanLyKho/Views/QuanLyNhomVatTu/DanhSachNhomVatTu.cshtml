@using QuanLyKho.Utility
@model QuanLyKho.Models.NhomVatTu_DSModel

<div class="table-responsive">
    <table class="table table-striped table-bordered verticle-middle table-hover  table-responsive-fix-big">
        <thead>
            <tr>
                <th scope="col" class="">STT</th>
                <th scope="col" class="">Mã nhóm</th>
                <th scope="col" class="">Tên nhóm</th>
                <th scope="col" class="">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{ var i = 0;}
            @if (Model.TBL_NhomVatTu != null && Model.TBL_NhomVatTu.Count > 0)
            {
                foreach (var item in Model.TBL_NhomVatTu)
                {
                    <tr>
                        <td>@(++i)</td>
                        <td>@item.MaNhom</td>
                        <td>@item.TenNhom</td>
                        <td>
                            @if (Global.IsAdmin())
                            {
                                <a href="#" onclick="FormNhomVatTu('@item.Id')" class="mr-3" title="Sửa"><i class="ti-pencil-alt"></i></a>
                                <a href="#" onclick="DeleteNhomVatTu('@item.Id')" class="mr-3" title="Xóa"><i class="ti-trash"></i></a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>
@Html.GenPaging().PagingHTML(Model.PageIndex, Model.Pagecount, Model.Total)
<input type="hidden" id="pageIndex" name="pageIndex" value="@Model.PageIndex" />
