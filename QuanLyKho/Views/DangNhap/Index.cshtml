<body>
    <header class="login-bv-topbar">
        <a href="https://benhvienk.vn/" target="_blank" rel="noopener noreferrer" class="login-bv-topbar-inner" title="Bệnh viện K">
            <img src="/Content/assets/images/benh-vien-k-logo.png" alt="Bệnh viện K" />
            <span class="login-bv-topbar-text">
                <strong>Bệnh viện K</strong>
                <small>Bệnh viện ung bướu trung ương</small>
            </span>
        </a>
    </header>
    <div class="main">
        <!-- Sing in  Form -->
        <section class="sign-in">
            <div class="containerBg">
                <div class="signin-content">
                    <div class="signin-image">
                        <figure>
                            <img src="/Content/images/bg2.png" alt="sing up image" />
                        </figure>
                    </div>

                    <div class="signin-form">
                        @*<h2 class="form-title">
                            <img src="/Content/images/logo.png" alt="sing up image" />
                        </h2>*@
                        <div class="title-login">@ViewBag.PhienBan</div>
                        <div class="fxt-style-line">
                            <h2>Đăng nhập</h2>
                        </div>
                        @using (Html.BeginForm("DoLogin", "DangNhap", new { backurl = ViewContext.HttpContext.Request.QueryString["backurl"] }, FormMethod.Post, new { @id = "loginform", @class = "mb-5" }))
                        {
                            <div class="form-group">
                                <label for="your_name">
                                    <i class="mdi mdi-account material-icons-name"></i>
                                </label>
                                @Html.TextBoxFor(x => x.UserName, new { @class = "form-control Input-New", @placeholder = "Tên đăng nhập" })
                                @Html.ValidationMessageFor(x => x.UserName)
                            </div>
                            <div class="form-group">
                                <label for="your_pass">
                                    <i class="mdi mdi-lock material-icons-name"></i>
                                </label>
                                @Html.PasswordFor(x => x.Password, new { @class = "form-control Input-New", @placeholder = "Mật khẩu" })
                                @Html.ValidationMessageFor(x => x.Password)
                            </div>

                            <div class="form-group form-button">
                                <input type="submit"
                                       name="signin"
                                       id="signin"
                                       class="form-submit-new"
                                       value="Đăng nhập" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>
    </div>
    <!-- #/ container -->
    <!-- Common JS -->
    <script src="/Content/assets/plugins/common/common.min.js"></script>
    <!-- Custom script -->
    <script src="/Content/js/custom.min.js"></script>
    <script src="/Content/js/settings.js"></script>
    <script src="/Content/js/gleek.js"></script>
    <script src="vendor/jquery/jquery.min.js"></script>
    <script src="js/main.js"></script>
</body>
</html>

<style>
    .field-validation-valid {
        width: 100%;
        color: #ff4848;
        font-weight: normal;
    }
</style>
<script>
    $("#TaiKhoan_DangNhap").focus();
    $('#loginform').submit(function (e) {
        e.preventDefault();
        $.ajax({
            type: "POST",
            url: $('#loginform').attr("action"),
            data: $('#loginform').serialize(),
            success: function (data) {
                if (data.Sucess) {
                    location.href = data.Url;
                }
                else {
                    DisplayErrors(data.Errors);
                }
            },
            error: function (data) {
                alert("Xảy ra lỗi hệ thống. Vui lòng thử lại sau.")
            },
        });
    });

    function DisplayErrors(errors) {
        $(".field-validation-valid").html("");
        for (var i = 0; i < errors.length; i++) {
            $("span[data-valmsg-for='" + errors[i].Key + "']").text(errors[i].Value[0]);
        }
    }
</script>